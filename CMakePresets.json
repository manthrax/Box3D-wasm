{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "windows",
      "displayName": "Windows (default Visual Studio)",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "macos",
      "displayName": "macOS (Xcode)",
      "generator": "Xcode",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "emscripten-release",
      "displayName": "Emscripten Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-box3d-wasm",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_MAKE_PROGRAM": "C:/Python312/Scripts/ninja.exe",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/tools/emsdk/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
        "BOX3D_EMSCRIPTEN_PTHREADS": "ON",
        "BOX3D_SAMPLES": "OFF",
        "BOX3D_UNIT_TESTS": "OFF",
        "BOX3D_VALIDATE": "OFF",
        "BOX3D_WASM_MODULE": "ON"
      }
    },
    {
      "name": "emscripten-release-single",
      "displayName": "Emscripten Release (Single Thread)",
      "inherits": "emscripten-release",
      "binaryDir": "${sourceDir}/build-box3d-wasm-single",
      "cacheVariables": {
        "BOX3D_EMSCRIPTEN_PTHREADS": "OFF"
      }
    },
    {
      "name": "emscripten-release-double",
      "displayName": "Emscripten Release (Double Precision)",
      "inherits": "emscripten-release",
      "binaryDir": "${sourceDir}/build-box3d-wasm-double",
      "cacheVariables": {
        "BOX3D_DOUBLE_PRECISION": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "windows-debug",   "configurePreset": "windows",     "configuration": "Debug" },
    { "name": "windows-release", "configurePreset": "windows",     "configuration": "Release" },
    { "name": "linux-debug",     "configurePreset": "linux-debug" },
    { "name": "linux-release",   "configurePreset": "linux-release" },
    { "name": "macos-debug",     "configurePreset": "macos",       "configuration": "Debug" },
    { "name": "macos-release",   "configurePreset": "macos",       "configuration": "Release" },
    { "name": "emscripten-release", "configurePreset": "emscripten-release", "targets": [ "box3d_wasm" ] },
    { "name": "emscripten-release-single", "configurePreset": "emscripten-release-single", "targets": [ "box3d_wasm" ] },
    { "name": "emscripten-release-double", "configurePreset": "emscripten-release-double", "targets": [ "box3d_wasm" ] }
  ]
}
